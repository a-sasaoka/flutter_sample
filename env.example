# .env ファイルのテンプレート
# このファイルを各環境に合わせてコピーして使用してください（例: .env.local, .env.dev ...）
# これらの値は Envied を通じて難読化・管理され、Git 管理からは除外されます。

# App Checkのデバッグ用トークン（Firebase Consoleから取得）
DEBUG_TOKEN=your_debug_token_here

# ios/Runner/Info.plist で使用される Google 逆クライアント ID
# Firebase コンソールからダウンロードした GoogleService-Info.plist の REVERSED_CLIENT_ID を入力してください。
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ※ その他の公開設定（BASE_URL, AI_MODEL, タイムアウト設定等）は、
#   config/flavor_*.json で管理されています。
